            pwm_tpm_CnV(TPM2, 1, 0);        //led

            mtr_Vrm_f();
        }
        else
        {
            pwm_tpm_CnV(TPM2, 1, TPM_MODULE);
            
            /*esse if existe para que caso ambas
            as variaveis resultem em um, o carrinho
            contiue a seguir em frente*/
            if (gus != 1)
            {
                mtr_Vrm_t();
            }
