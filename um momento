#define TPM_MODULE 2000         // Define a frequência do PWM fpwm = (TPM_CLK / (TPM_MODULE * PS)

#define INPUT_PORT2 DT_NODELABEL(gpiob)
#define pino_pronto 16
#define max TPM_MODULE * 8 / 10
#define min 2 * TPM_MODULE - 2 * max

#define INPUT_PORT      DT_NODELABEL(gpioa)  // Porta A = GPIO_0 no seu .dts
#define INPUT_PIN       1         // PTA1
#define INPUT_PIN2      2         // PTA2

void Led_rgb (int LED_VERMELHO, int LED_VERDE, int LED_AZUL){
    //multiplo pra facilitar o processo pra ficar bonito
    int m = floor(TPM_MODULE/256);
        pwm_tpm_CnV(TPM2, 0, TPM_MODULE - LED_VERMELHO * m);
        pwm_tpm_CnV(TPM2, 1, TPM_MODULE - LED_VERDE * m);
        pwm_tpm_CnV(TPM0, 1, TPM_MODULE - LED_AZUL * m);
}

void motor_f(int n, int m, int v)             //função pro motor vermelho ir pra frente
{
        pwm_tpm_CnV(TPM0, n, max + v);
        pwm_tpm_CnV(TPM0, m, max);
}

void motor_t(int n, int m)             //função pro motor vermelho ir pra trás
{
        pwm_tpm_CnV(TPM0, n, 0);
        pwm_tpm_CnV(TPM0, m, min);
}

void quieto(void){
        pwm_tpm_CnV(TPM0, 3, 0);
        pwm_tpm_CnV(TPM0, 4, TPM_MODULE);
        pwm_tpm_CnV(TPM0, 3, 0);
        pwm_tpm_CnV(TPM0, 4, TPM_MODULE);
}

enum estado_sensor {
    INFRA_VERMELHO,
    ULTRASSOM,
    QUIETO
};

int sensor_infra(void){
    const struct device *input_dev;
    input_dev = DEVICE_DT_GET(INPUT_PORT);
    int infra_vrm, gus, infra_vrd, tavo;
    
        //habilita o pino como input, dos sensores infravermelho e do ultrassom
        infra_vrm = gpio_pin_configure(input_dev, INPUT_PIN, GPIO_INPUT);
        infra_vrd = gpio_pin_configure(input_dev, INPUT_PIN2, GPIO_INPUT);
    
        gus = gpio_pin_get(input_dev, INPUT_PIN);
        tavo = gpio_pin_get(input_dev, INPUT_PIN2);
        if(gus == 0 && tavo == 1){
            printk("direita");
            return 1;
            
        }
        else if(gus == 1 && tavo == 0){
            printk("esquerda");
            return 2;
        }
        else if(gus == tavo){
            printk("torto");
            return 3;
        }
}

